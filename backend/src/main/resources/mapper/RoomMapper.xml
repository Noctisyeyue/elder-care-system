<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.eldercare.system.mapper.RoomMapper">

    <select id="getFloorList" resultType="java.lang.String">
        select distinct floor
        from room
        where del_flag = '0'
        order by floor
    </select>

    <select id="getFloorListByBuilding" parameterType="string" resultType="java.lang.String">
        select distinct floor
        from room
        where del_flag = '0'
        and building = #{building}
        order by floor
    </select>
</mapper>
